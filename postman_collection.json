{
  "info": {
    "name": "Event Booking System API",
    "description": "Complete API collection for Event Booking System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register Organizer",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"organizer@example.com\",\n  \"password\": \"password123\",\n  \"name\": \"John Organizer\",\n  \"role\": \"organizer\"\n}"
            },
            "url": {"raw": "http://localhost:5000/api/auth/register"}
          }
        },
        {
          "name": "Register Customer",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"customer@example.com\",\n  \"password\": \"password123\",\n  \"name\": \"Jane Customer\",\n  \"role\": \"customer\"\n}"
            },
            "url": {"raw": "http://localhost:5000/api/auth/register"}
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"organizer@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {"raw": "http://localhost:5000/api/auth/login"}
          }
        }
      ]
    },
    {
      "name": "Events (Public)",
      "item": [
        {
          "name": "Get All Events",
          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:5000/api/events"}
          }
        },
        {
          "name": "Get Event by ID",
          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:5000/api/events/1"}
          }
        }
      ]
    },
    {
      "name": "Events (Organizer)",
      "item": [
        {
          "name": "Create Event",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{organizer_token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Tech Conference 2024\",\n  \"description\": \"Annual technology conference\",\n  \"date\": \"2024-12-31T10:00:00\",\n  \"location\": \"Convention Center\",\n  \"total_tickets\": 100,\n  \"price\": 99.99\n}"
            },
            "url": {"raw": "http://localhost:5000/api/events"}
          }
        },
        {
          "name": "Update Event",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{organizer_token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Tech Conference 2024 - UPDATED\",\n  \"location\": \"Grand Convention Center\"\n}"
            },
            "url": {"raw": "http://localhost:5000/api/events/1"}
          }
        },
        {
          "name": "Delete Event",
          "request": {
            "method": "DELETE",
            "header": [
              {"key": "Authorization", "value": "Bearer {{organizer_token}}"}
            ],
            "url": {"raw": "http://localhost:5000/api/events/1"}
          }
        },
        {
          "name": "Get My Events",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer {{organizer_token}}"}
            ],
            "url": {"raw": "http://localhost:5000/api/organizer/events"}
          }
        },
        {
          "name": "Get Event Bookings",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer {{organizer_token}}"}
            ],
            "url": {"raw": "http://localhost:5000/api/organizer/events/1/bookings"}
          }
        }
      ]
    },
    {
      "name": "Bookings (Customer)",
      "item": [
        {
          "name": "Book Tickets",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{customer_token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event_id\": 1,\n  \"tickets_count\": 3\n}"
            },
            "url": {"raw": "http://localhost:5000/api/bookings"}
          }
        },
        {
          "name": "Get My Bookings",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer {{customer_token}}"}
            ],
            "url": {"raw": "http://localhost:5000/api/bookings"}
          }
        }
      ]
    }
  ]
}
